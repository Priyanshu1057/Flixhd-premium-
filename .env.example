# ── Required ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # Bot token from @BotFather
MONGODB_URI=               # MongoDB connection string (MongoDB Atlas free tier works)
ADMIN_CHANNEL_ID=          # Numeric ID of your admin channel e.g. -1001234567890
ADMIN_USER_ID=             # Your Telegram numeric user ID
UPI_ID=                    # Your UPI ID e.g. yourname@upi

# ── Optional but recommended ───────────────────────────────
LOG_CHANNEL_ID=            # Numeric ID of a separate log channel (leave blank to skip)
SELF_PING_URL=             # Your public service URL e.g. https://your-bot.onrender.com
                           # (keeps Render/Koyeb free instance alive — set after first deploy)

# ── Telegram MTProto (my.telegram.org) ────────────────────
API_ID=                    # Integer App api_id
API_HASH=                  # App api_hash string
